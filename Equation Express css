body {
  font-family: Arial, sans-serif;
  text-align: center;
  background: #f4f4f4;
  padding: 40px;
}

h1 {
  color: #2c3e50;
}

input, button {
  padding: 10px;
  margin: 10px;
  font-size: 16px;
}

button {
  background: #3498db;
  color: white;
  border: none;
  cursor: pointer;
}

button:hover {
  background: #2980b9;
}

#result {
  font-weight: bold;
  margin-top: 15px;
}
